<Window x:Class="CybersecurityChatbotWPF.Views.TaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Task Assistant" 
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E"
        ResizeMode="CanResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#16213E" CornerRadius="10" Margin="5" Padding="15" BorderBrush="#0F3460" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Cybersecurity Task Assistant" 
                           Foreground="#00FFAA" 
                           FontSize="20" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Manage your cybersecurity tasks and reminders" 
                           Foreground="#888888" 
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Task List -->
        <Border Grid.Row="1" Background="#16213E" CornerRadius="10" Margin="5" Padding="10" BorderBrush="#0F3460" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Filter Buttons -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
                    <Button x:Name="btnAllTasks" 
                            Content="All" 
                            Width="60" 
                            Height="25"
                            Background="#0F3460"
                            Foreground="#FFFFFF"
                            FontWeight="Bold"
                            Click="BtnAllTasks_Click"/>
                    <Button x:Name="btnPendingTasks" 
                            Content="Pending" 
                            Width="70" 
                            Height="25"
                            Margin="5,0,0,0"
                            Background="#0F3460"
                            Foreground="#FFFFFF"
                            FontWeight="Bold"
                            Click="BtnPendingTasks_Click"/>
                    <Button x:Name="btnCompletedTasks" 
                            Content="Completed" 
                            Width="80" 
                            Height="25"
                            Margin="5,0,0,0"
                            Background="#0F3460"
                            Foreground="#FFFFFF"
                            FontWeight="Bold"
                            Click="BtnCompletedTasks_Click"/>
                </StackPanel>

                <!-- Task List View -->
                <ListView x:Name="lstTasks" 
                          Grid.Row="1"
                          Background="#0F3460"
                          Foreground="#FFFFFF"
                          BorderBrush="Transparent"
                          FontSize="13"
                          Margin="0,5,0,0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Status" Width="80" DisplayMemberBinding="{Binding GetStatusDisplay}"/>
                            <GridViewColumn Header="Title" Width="200" DisplayMemberBinding="{Binding Title}"/>
                            <GridViewColumn Header="Description" Width="250" DisplayMemberBinding="{Binding Description}"/>
                            <GridViewColumn Header="Reminder" Width="150" DisplayMemberBinding="{Binding GetReminderDisplay}"/>
                            <GridViewColumn Header="Created" Width="150" DisplayMemberBinding="{Binding CreatedDate}"/>
                        </GridView>
                    </ListView.View>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="{x:Type ListViewItem}">
                            <Setter Property="Background" Value="#0F3460"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Setter Property="Margin" Value="0,2,0,2"/>
                            <Setter Property="Padding" Value="5,2,5,2"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                    <Setter Property="Foreground" Value="#00FFAA"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Border>

        <!-- Controls -->
        <Border Grid.Row="2" Background="#16213E" CornerRadius="10" Margin="5" Padding="10" BorderBrush="#0F3460" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0" HorizontalAlignment="Left">
                    <Button x:Name="btnAddTask" 
                            Content="Add Task" 
                            Width="100" 
                            Height="35"
                            Background="#00FFAA"
                            Foreground="#1A1A2E"
                            FontWeight="Bold"
                            Click="BtnAddTask_Click"
                            Margin="0,0,5,0"/>
                    <Button x:Name="btnCompleteTask" 
                            Content="Complete" 
                            Width="100" 
                            Height="35"
                            Background="#E94560"
                            Foreground="#FFFFFF"
                            FontWeight="Bold"
                            Click="BtnCompleteTask_Click"
                            Margin="5,0,0,0"/>
                    <Button x:Name="btnDeleteTask" 
                            Content="Delete" 
                            Width="100" 
                            Height="35"
                            Background="#FF4444"
                            Foreground="#FFFFFF"
                            FontWeight="Bold"
                            Click="BtnDeleteTask_Click"
                            Margin="5,0,0,0"/>
                    <Button x:Name="btnRefresh" 
                            Content="Refresh" 
                            Width="100" 
                            Height="35"
                            Background="#0F3460"
                            Foreground="#FFFFFF"
                            FontWeight="Bold"
                            Click="BtnRefresh_Click"
                            Margin="5,0,0,0"/>
                </WrapPanel>

                <Button x:Name="btnClose" 
                        Grid.Column="1"
                        Content="Close" 
                        Width="80" 
                        Height="35"
                        Background="#FF4444"
                        Foreground="#FFFFFF"
                        FontWeight="Bold"
                        Click="BtnClose_Click"
                        Margin="10,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>